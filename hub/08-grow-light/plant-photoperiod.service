[Unit]
Description=Plant Autonomy Testbed - hub-side grow-light photoperiod enforcement
After=network-online.target

[Service]
Type=oneshot
User=basilpi
EnvironmentFile=/etc/plant-hub/credentials
WorkingDirectory=/home/basilpi/plant-hub
ExecStart=/usr/bin/python3 /home/basilpi/plant-hub/photoperiod.py
